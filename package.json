{
  "name": "NoduleRisk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:app": "playwright test app.spec.ts",
    "test:e2e:external": "playwright test --config playwright.external.config.ts",
    "test:e2e:external:quick": "playwright test --config playwright.external.config.ts --grep @curated",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "next": "15.5.15",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "19",
    "@types/react-dom": "19",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
